{
  "site_name": "NRAPA Members Portal",
  "description": "National Rifle & Pistol Association of South Africa - Member Portal",
  "version": "2026-01-29",
  "last_updated": "2026-01-29",
  "authentication": {
    "public_routes": [
      {
        "route": "home",
        "path": "/",
        "view": "welcome",
        "description": "Public landing page"
      },
      {
        "route": "certificates.verify",
        "path": "/verify/{qr_code}",
        "view": "pages.verify",
        "description": "Public certificate verification via QR code"
      }
    ],
    "dev_routes": {
      "environment": ["local", "development", "testing"],
      "routes": [
        {
          "route": "dev.login",
          "path": "/dev/login/{role}",
          "description": "Quick login for testing (developer, owner, admin, member)",
          "redirects": {
            "developer": "developer.dashboard",
            "owner": "owner.dashboard",
            "admin": "admin.dashboard",
            "member": "dashboard"
          }
        }
      ]
    },
    "impersonation_routes": {
      "middleware": ["auth"],
      "routes": [
        {
          "route": "dev.impersonate",
          "path": "/dev/impersonate/{user}",
          "description": "Developer-only: Login as any user",
          "requires_role": "developer"
        },
        {
          "route": "dev.stop-impersonating",
          "path": "/dev/stop-impersonating",
          "description": "Return to original developer account"
        }
      ]
    }
  },
  "member_area": {
    "section": "MEMBER AREA",
    "description": "Available to all authenticated users (including free members)",
    "middleware": ["auth", "verified"],
    "sidebar_items": [
      {
        "label": "Dashboard",
        "route": "dashboard",
        "path": "/dashboard",
        "icon": "home",
        "view": "pages::member.dashboard",
        "roles": ["member", "admin", "owner", "developer"],
        "description": "Member dashboard with overview"
      },
      {
        "label": "My Membership",
        "route": "membership.index",
        "path": "/membership",
        "icon": "badge",
        "view": "pages::member.membership.index",
        "roles": ["member", "admin", "owner", "developer"],
        "description": "View membership status and details",
        "sub_routes": [
          {
            "route": "membership.select-package",
            "path": "/membership/select-package",
            "view": "pages::member.membership.select-package",
            "description": "Select membership package (for free members)"
          },
          {
            "route": "membership.apply",
            "path": "/membership/apply",
            "view": "pages::member.membership.apply",
            "description": "Apply for membership"
          },
          {
            "route": "membership.payment",
            "path": "/membership/payment/{membership}",
            "view": "pages::member.membership.payment",
            "description": "Payment page for membership"
          },
          {
            "route": "membership.show",
            "path": "/membership/{membership}",
            "view": "pages::member.membership.show",
            "description": "View specific membership details"
          }
        ]
      },
      {
        "label": "Certificates & Endorsements",
        "route": "certificates.index",
        "path": "/certificates",
        "icon": "document-check",
        "view": "pages::member.certificates.index",
        "roles": ["member", "admin", "owner", "developer"],
        "description": "View membership certificates and issued endorsement letters",
        "requires_active_membership": true,
        "includes": ["certificates", "endorsements"],
        "sub_routes": [
          {
            "route": "certificates.show",
            "path": "/certificates/{certificate}",
            "view": "pages::member.certificates.show",
            "description": "View specific certificate"
          },
          {
            "route": "certificates.download",
            "path": "/certificates/{certificate}/download",
            "description": "Download certificate PDF"
          },
          {
            "route": "certificates.wallet.apple",
            "path": "/certificates/{certificate}/wallet/apple",
            "description": "Download Apple Wallet pass (membership cards only)"
          },
          {
            "route": "certificates.wallet.google",
            "path": "/certificates/{certificate}/wallet/google",
            "description": "Download Google Wallet pass (membership cards only)"
          }
        ]
      },
      {
        "label": "Documents",
        "route": "documents.index",
        "path": "/documents",
        "icon": "document",
        "view": "pages::member.documents.index",
        "roles": ["member", "admin", "owner", "developer"],
        "description": "Upload and manage documents",
        "requires_active_membership": true,
        "sub_routes": [
          {
            "route": "documents.upload",
            "path": "/documents/upload",
            "view": "pages::member.documents.upload",
            "description": "Upload new document"
          },
          {
            "route": "documents.show",
            "path": "/documents/{document}",
            "view": "pages::member.documents.show",
            "description": "View document details"
          },
          {
            "route": "documents.preview",
            "path": "/documents/{document}/preview",
            "description": "Preview document file (streams from storage)"
          }
        ]
      },
      {
        "label": "Activities",
        "route": "activities.index",
        "path": "/activities",
        "icon": "clipboard",
        "view": "pages::member.activities.index",
        "roles": ["member", "admin", "owner", "developer"],
        "description": "Submit and track shooting activities",
        "requires_active_membership": true,
        "sub_routes": [
          {
            "route": "activities.submit",
            "path": "/activities/submit",
            "view": "pages::member.activities.submit",
            "description": "Submit new activity"
          },
          {
            "route": "activities.show",
            "path": "/activities/{activity}",
            "view": "pages::member.activities.show",
            "description": "View activity details"
          },
          {
            "route": "activities.edit",
            "path": "/activities/{activity}/edit",
            "view": "pages::member.activities.edit",
            "description": "Edit pending activity"
          }
        ]
      },
      {
        "label": "Endorsement Requests",
        "route": "member.endorsements.index",
        "path": "/endorsements",
        "icon": "document-text",
        "view": "pages::member.endorsements.index",
        "roles": ["member", "admin", "owner", "developer"],
        "description": "Request endorsement letters for firearm applications",
        "requires_active_membership": true,
        "sub_routes": [
          {
            "route": "member.endorsements.create",
            "path": "/endorsements/create",
            "view": "pages::member.endorsements.create",
            "description": "Create new endorsement request (wizard form)"
          },
          {
            "route": "member.endorsements.edit",
            "path": "/endorsements/{request}/edit",
            "view": "pages::member.endorsements.create",
            "description": "Edit draft endorsement request"
          },
          {
            "route": "member.endorsements.show",
            "path": "/endorsements/{request}",
            "view": "pages::member.endorsements.show",
            "description": "View endorsement request details"
          },
          {
            "route": "member.endorsements.preview",
            "path": "/endorsements/{request}/preview",
            "description": "Preview endorsement letter template"
          },
          {
            "route": "member.endorsements.letter",
            "path": "/endorsements/{request}/letter",
            "description": "Download issued endorsement letter PDF (only when status = 'issued')"
          }
        ]
      },
      {
        "label": "Virtual Safe",
        "route": "armoury.index",
        "path": "/armoury",
        "icon": "shield-check",
        "view": "pages::member.armoury.index",
        "roles": ["member", "admin", "owner", "developer"],
        "description": "Virtual Safe - List all firearms",
