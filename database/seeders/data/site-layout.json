        "roles": ["admin", "owner", "developer"],
        "description": "Manage all members",
        "sub_routes": [
          {
            "route": "admin.members.show",
            "path": "/admin/members/{user}",
            "view": "pages::admin.members.show",
            "description": "View member details (includes certificates AND endorsement letters)",
            "features": [
              "View member profile",
              "Issue certificates",
              "View issued certificates",
              "View issued endorsement letters",
              "Download endorsement PDFs",
              "Manage membership",
              "Reset password/2FA",
              "Delete certificates"
            ]
          }
        ]
      },
      {
        "label": "Endorsements",
        "route": "admin.endorsements.index",
        "path": "/admin/endorsements",
        "icon": "document-text",
        "view": "pages::admin.endorsements.index",
        "roles": ["admin", "owner", "developer"],
        "description": "Review and approve endorsement requests",
        "sub_routes": [
          {
            "route": "admin.endorsements.show",
            "path": "/admin/endorsements/{request}",
            "view": "pages::admin.endorsements.show",
            "description": "Review specific endorsement request",
            "features": [
              "View request details",
              "Check member compliance",
              "Approve request (with non-compliance warning)",
              "Reject request",
              "Request additional documents",
              "Generate and issue PDF letter",
              "Download issued letter"
            ]
          },
          {
            "route": "admin.endorsements.preview",
            "path": "/admin/endorsements/{request}/preview",
            "description": "Preview endorsement letter template"
          },
          {
            "route": "admin.endorsements.download",
            "path": "/admin/endorsements/{request}/download",
            "description": "Download issued endorsement letter PDF"
          }
        ],
        "workflow": {
          "statuses": ["draft", "submitted", "under_review", "pending_documents", "approved", "issued", "rejected", "cancelled"],
          "notifications": {
            "on_submit": "Admins receive notification when member submits request",
            "type": "endorsement_request",
            "preference": "notify_endorsement_request"
          }
        }
      },
      {
        "label": "Approvals",
        "route": "admin.approvals.index",
        "path": "/admin/approvals",
        "icon": "check-circle",
        "view": "pages::admin.approvals.index",
        "roles": ["admin", "owner", "developer"],
        "description": "Review and approve pending items",
        "collapsible": true,
        "children": [
          {
            "label": "All Approvals",
            "route": "admin.approvals.index",
            "path": "/admin/approvals",
            "icon": "check-circle",
            "description": "View all pending approvals"
          },
          {
            "label": "Documents",
            "route": "admin.documents.index",
            "path": "/admin/documents",
            "icon": "document-text",
            "view": "pages::admin.documents.index",
            "description": "Review and verify member documents",
            "pending_count_field": "member_documents.status = 'pending'",
            "sub_routes": [
              {
                "route": "admin.documents.show",
                "path": "/admin/documents/{document}",
                "view": "pages::admin.documents.show",
                "description": "Review specific document"
              },
              {
                "route": "admin.documents.preview",
                "path": "/admin/documents/{document}/preview",
                "description": "Preview document file"
              }
            ]
          },
          {
            "label": "Memberships",
            "route": "admin.approvals.index",
            "path": "/admin/approvals?type=memberships",
            "icon": "badge",
            "description": "Approve membership applications",
            "pending_count_field": "memberships.status = 'applied'"
          },
          {
            "label": "Activities",
            "route": "admin.approvals.index",
            "path": "/admin/approvals?type=activities",
            "icon": "clipboard",
            "description": "Approve shooting activities",
            "pending_count_field": "shooting_activities.status = 'pending'",
            "sub_routes": [
              {
                "route": "admin.activities.index",
                "path": "/admin/activities",
                "view": "pages::admin.activities.index",
                "description": "List all activities"
              },
              {
                "route": "admin.activities.show",
                "path": "/admin/activities/{activity}",
                "view": "pages::admin.activities.show",
                "description": "Review specific activity"
              }
            ]
          }
        ]
      },
      {
        "label": "Certificates",
        "route": "admin.certificates.index",
        "path": "/admin/certificates",
        "icon": "document-check",
        "view": "pages::member.certificates.index",
        "roles": ["admin", "owner", "developer"],
        "description": "View all certificates and endorsement letters",
        "sub_routes": [
          {
            "route": "admin.certificates.show",
            "path": "/admin/certificates/{certificate}",
            "view": "pages::member.certificates.show",
            "description": "View specific certificate"
          },
          {
            "route": "admin.certificates.download",
            "path": "/admin/certificates/{certificate}/download",
            "description": "Download certificate PDF"
          },
          {
            "route": "admin.certificates.wallet.apple",
            "path": "/admin/certificates/{certificate}/wallet/apple",
            "description": "Download Apple Wallet pass"
          }
        ]
      }
