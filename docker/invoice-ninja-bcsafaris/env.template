# Invoice Ninja Configuration - BC Safaris
# Copy to .env and fill in your values

# App Settings
IN_APP_URL=https://invoice.bcsafaris.africa
IN_APP_KEY=  # Generate with: docker compose run --rm invoiceninja php artisan key:generate --show
IN_APP_DEBUG=false

# Database
IN_DB_ROOT_PASSWORD=  # Strong password for MariaDB root
IN_DB_DATABASE=invoiceninja
IN_DB_USERNAME=invoiceninja
IN_DB_PASSWORD=  # Strong password for app database user

# Email (for sending invoices)
IN_MAIL_MAILER=smtp
IN_MAIL_HOST=smtp.example.com
IN_MAIL_PORT=587
IN_MAIL_USERNAME=
IN_MAIL_PASSWORD=
IN_MAIL_ENCRYPTION=tls
IN_MAIL_FROM_ADDRESS=invoices@bcsafaris.africa
IN_MAIL_FROM_NAME="BC Safaris"
